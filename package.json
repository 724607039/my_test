{
  "name": "low-code-drag-drop-monorepo",
  "private": true,
  "version": "1.0.0",
  "description": "低代码可拖拽组件系统Monorepo",
  "scripts": {
    "dev": "cd apps/web-antd && pnpm run dev",
    "build": "cd apps/web-antd && pnpm run build",
    "preview": "cd apps/web-antd && pnpm run preview",
    "lint": "eslint . --ext .vue,.js,.ts --fix",
    "format": "prettier --write .",
    "prepare": "husky install"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^4.2.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "eslint-plugin-vue": "^9.27.0",
    "husky": "^8.0.0",
    "lint-staged": "^16.4.0",
    "prettier": "^2.8.8",
    "typescript": "^4.9.5"
  },
  "lint-staged": {
    "*.{js,jsx,vue}": "eslint --fix"
  }
}
